# Copy to .env and tweak

# ClickHouse (local docker by default; swap to your $400-credit Cloud host)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=cortexos
CLICKHOUSE_PASSWORD=cortexos
CLICKHOUSE_DB=cortexos
CLICKHOUSE_SECURE=false

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cortexos123

# Ollama (local)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# Datadog (optional; leave blank to no-op)
DD_API_KEY=
DD_SITE=us5.datadoghq.com
DD_SERVICE=cortexos
DD_ENV=hackathon
